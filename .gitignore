# ── 运行时 / 日志（非源码） ──
logs/
*.log
*.log.1
__pycache__/
*.pyc

# ── 备份归档（体积大 / 可能含机密，绝不进公开仓库） ──
*.zip
*.codeg.zip
codeg-backup-*
*.bak
secrets-backup-*
memory-backup/

# ── 机密：绝对不可提交 ──
secrets-backup/
.secrets/
providers.json
*.patch.json
.env
.env.*
**/openclaw.json
**/auth-profiles.json
**/config.yml
**/credentials/
*.pem
*.key
id_rsa*
*service-account*.json
# 注：文档 PDF（docs/*.pdf、README.pdf）允许提交；secrets-backup 已整体忽略
